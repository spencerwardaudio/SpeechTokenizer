    "num_warmup_steps": 1000,
    "betas": [0.9, 0.99],
    "adam_b2": 0.9,
    "lr_decay": 0.98,
    "seed": 42,
    "segment_size": 48000,
    "wd": 0,
    "num_workers": 4,
    "log_steps": 100,
    "stdout_steps": 10,
    "save_model_steps": 5000,
    "num_ckpt_keep": 3,
    "showpiece_num": 8,
    "drop_last": true
}
